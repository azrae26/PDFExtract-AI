# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PDF sample files (keep debug scripts)
pdf/*.pdf

# 使用者本機設定（prompt、apiKey 等）
data/settings.json

# 匯出輸出資料夾
exports/

# PDF 字型資源（cmap、標準字型，體積大且可於執行時下載）
public/cmaps/
public/standard_fonts/
